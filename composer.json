{
    "name": "emberrenewed/laravel-auth-kit",
    "description": "Laravel authentication kit with multi-driver support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0|^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Technobase\\AuthKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Technobase\\AuthKit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Technobase\\AuthKit\\AuthKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
