{
  "info": {
    "name": "TechnoBase Laravel Auth Kit",
    "description": "Auth Kit API — Google, Facebook, and Iraqi phone OTP (Asiacell / Korek / Zain).\n\nbase_url = http://127.0.0.1:8000\nRun: php artisan serve --host=127.0.0.1 --port=8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "iraqi_phone", "value": "+9647501234567" },
    { "key": "otp_code", "value": "" },
    { "key": "google_access_token", "value": "" },
    { "key": "facebook_access_token", "value": "" }
  ],
  "item": [
    {
      "name": "Providers",
      "item": [
        {
          "name": "List providers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has drivers', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/providers"
          }
        }
      ]
    },
    {
      "name": "Social",
      "description": "Set google_access_token / facebook_access_token in collection variables.",
      "item": [
        {
          "name": "Google",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"access_token\": \"{{google_access_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/google",
            "description": "Set {{google_access_token}} from Google Sign-In."
          }
        },
        {
          "name": "Facebook",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"access_token\": \"{{facebook_access_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/facebook",
            "description": "Set {{facebook_access_token}} from Facebook Login."
          }
        }
      ]
    },
    {
      "name": "Iraqi Phone OTP",
      "description": "Asiacell (077/078), Korek (075), Zain Iraq (079).",
      "item": [
        {
          "name": "Phone OTP send",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has carrier', () => pm.expect(json.carrier).to.be.oneOf(['asiacell', 'korek', 'zain']));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{iraqi_phone}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/otp/phone/send",
            "description": "Examples: +9647501234567 (Korek), +9647701234567 (Asiacell), +9647901234567 (Zain)."
          }
        },
        {
          "name": "Phone OTP verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{iraqi_phone}}\",\n  \"code\": \"{{otp_code}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/otp/phone/verify",
            "description": "Set {{otp_code}} from logs/SMS. Issues Sanctum token."
          }
        },
        {
          "name": "Phone OTP send (invalid → 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+15551234567\"\n}"
            },
            "url": "{{base_url}}/api/auth/otp/phone/send"
          }
        }
      ]
    },
    {
      "name": "Logout",
      "item": [
        {
          "name": "Logout",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const t = pm.collectionVariables.get('token');",
                  "if (!t) throw new Error('Run Google/Facebook/Phone verify first — {{token}} is empty.');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{base_url}}/api/auth/logout"
          }
        }
      ]
    }
  ]
}
